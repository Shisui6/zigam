# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored — never commit real keys.

# ---- Supabase (Project Settings -> API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Paystack (Dashboard -> Settings -> API Keys & Webhooks) ----
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx

# ---- Site ----
# Public base URL, used to build Paystack callback links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Pre-launch "coming soon" gate ----
# Set to "true" to redirect all visitors to /launch until the launch date.
NEXT_PUBLIC_COMING_SOON=false
